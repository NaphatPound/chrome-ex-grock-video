{
  "manifest_version": 3,
  "name": "Grok AI Video Generator",
  "version": "1.0.0",
  "description": "Auto upload images to Grok AI and generate videos with custom prompts",
  "permissions": [
    "storage",
    "downloads",
    "activeTab",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "https://grok.com/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://grok.com/*"],
      "js": ["content.js"],
      "css": ["content-styles.css"],
      "run_at": "document_idle"
    }
  ]
}
